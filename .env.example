# ---------------------------------------------------------------------------
# TEMPLATE ONLY — this file IS committed to git. Never put real values here.
#
# Copy it to .env and fill that in instead:   cp .env.example .env
# .env is gitignored; this file is not.
# ---------------------------------------------------------------------------

# Google OAuth — see GOOGLE_SETUP.md for the full walkthrough. Short version:
#   1. console.cloud.google.com/apis/library/gmail.googleapis.com  -> Enable
#   2. console.cloud.google.com/auth/branding   -> app name, support email
#   3. console.cloud.google.com/auth/audience   -> External, then "Publish app"
#   4. console.cloud.google.com/auth/scopes     -> add exactly these three:
#         openid
#         .../auth/userinfo.email
#         .../auth/gmail.send        (never gmail.readonly — restricted tier)
#   5. console.cloud.google.com/auth/clients    -> Create client
#         type: Web application  (hosted server) — Desktop app is for mcp_server/
#         redirect URI, exactly:  <PUBLIC_BASE_URL>/auth/callback
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Public origin of the server. Must match the redirect URI in Google Console.
# Railway and Render inject their own domain, so you can leave this unset there.
PUBLIC_BASE_URL=http://localhost:8000

# Storage. Unset DATABASE_URL = SQLite, which is fine for local dev.
# In production use Postgres (Neon/Supabase): no volume to mount, nothing lost
# on redeploy, backups you didn't have to build.
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/setu?sslmode=require
DATABASE_PATH=data/app.db

# Origin allowed to call /api/stats from a browser. Set to your deployed frontend.
FRONTEND_ORIGIN=http://localhost:3000

DAILY_SEND_LIMIT=80
EMAIL_DELAY=5

# Off: emails go to whatever address the model supplies.
# Set true to require an MX check + a real source URL before every send, which
# blocks addresses the model guessed. Those bounce, and bounces lower a Gmail
# account's sending reputation. Turn on if deliverability starts suffering.
VERIFY_HR_EMAILS=false

# --- Below here is only for the standalone desktop modes (app.py / main.py) ---
YOUR_NAME=Your Full Name
YOUR_EMAIL=your.email@gmail.com
RESUME_LINK=https://your-resume-link.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
